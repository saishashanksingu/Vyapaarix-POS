{
  "name": "supermarket-saas",
  "version": "1.0.0",
  "description": "Complete Point of Sale (POS) and Supermarket Management System",
  "main": "backend/server.js",
  "scripts": {
    "setup-deploy": "node setup-deployment.js",
    "dev": "concurrently \"cd backend && npm start\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm run dev",
    "seed": "cd backend && npm run seed"
  },
  "keywords": [
    "pos",
    "supermarket",
    "saas",
    "point-of-sale",
    "inventory-management"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.2.4",
    "pdfkit": "^0.17.2"
  }
}
