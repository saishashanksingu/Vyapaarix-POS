# ===========================================
# MONGODB Configuration
# ===========================================

# LOCAL DEVELOPMENT (using MongoDB Compass locally)
MONGODB_URI=mongodb://localhost:27017/supermarket

# PRODUCTION (using MongoDB Atlas cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/supermarket?retryWrites=true&w=majority

# ===========================================
# JWT Authentication
# ===========================================
# Use a long random string in production!
JWT_SECRET=change_me_to_very_long_random_secret

# ===========================================
# Server Configuration
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# CORS Configuration (for production)
# ===========================================
# Uncomment and add your Vercel domain
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourdomain.com
