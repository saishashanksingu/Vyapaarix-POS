# Database Configuration
# Local development: mongodb://127.0.0.1:27017/supermarket
# Production (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/supermarket
MONGODB_URI=mongodb://127.0.0.1:27017/supermarket

# JWT Secret - Use a long random string in production!
JWT_SECRET=change_me_to_very_long_random_secret

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (optional) - add comma-separated domains for production
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourdomain.com
